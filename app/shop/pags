
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ShopDemo – Grau • Blau • Grün • Orange • Gelb</title>

  <style>
    /* =========================
       Farbpalette (anpassbar)
       ========================= */
    :root{
      --gray-900:#0f172a;
      --gray-800:#1f2937;
      --gray-700:#334155;
      --gray-200:#e5e7eb;
      --gray-100:#f3f4f6;
      --white:#ffffff;

      --blue-600:#2563eb;   /* Primär */
      --blue-700:#1d4ed8;

      --green-600:#16a34a;  /* Erfolg */
      --orange-500:#f97316; /* Akzent */
      --yellow-400:#facc15; /* Sale */

      --shadow: 0 10px 30px rgba(2,6,23,.12);
      --radius: 18px;
    }

    /* =========================
       Base
       ========================= */
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      color: var(--gray-900);
      background:
        radial-gradient(1200px 600px at 20% -10%, rgba(37,99,235,.12), transparent 55%),
        radial-gradient(900px 500px at 110% 10%, rgba(249,115,22,.14), transparent 55%),
        radial-gradient(900px 500px at 60% 120%, rgba(250,204,21,.12), transparent 55%),
        var(--gray-100);
    }
    a{color:inherit; text-decoration:none}
    img{max-width:100%; display:block}
    .container{max-width:1120px; margin:0 auto; padding:0 18px}
    .sr-only{
      position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden;
      clip:rect(0,0,0,0); white-space:nowrap; border:0;
    }

    /* =========================
       Header
       ========================= */
    header{
      position:sticky; top:0; z-index:50;
      background: rgba(243,244,246,.75);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(51,65,85,.10);
    }
    .topbar{
      display:flex; align-items:center; justify-content:space-between;
      gap:12px;
      padding:14px 0;
    }
    .brand{
      display:flex; align-items:center; gap:10px; font-weight:800; letter-spacing:.2px;
    }
    .logo{
      width:40px; height:40px; border-radius:14px;
      background: linear-gradient(135deg, var(--blue-600), var(--orange-500));
      box-shadow: var(--shadow);
      position:relative;
    }
    .logo:after{
      content:"";
      position:absolute; inset:10px;
      border-radius:10px;
      background: linear-gradient(135deg, rgba(250,204,21,.95), rgba(22,163,74,.9));
      mix-blend-mode: screen;
      opacity:.9;
    }
    nav{
      display:flex; align-items:center; gap:16px;
      color: var(--gray-700);
      font-weight:600;
    }
    nav a{
      padding:8px 10px; border-radius:12px;
      transition: background .15s ease, color .15s ease;
    }
    nav a:hover{ background: rgba(37,99,235,.10); color: var(--gray-900); }

    .actions{display:flex; align-items:center; gap:10px}
    .search{
      display:flex; align-items:center; gap:8px;
      padding:10px 12px;
      background: var(--white);
      border:1px solid rgba(51,65,85,.10);
      border-radius: 999px;
      box-shadow: 0 6px 18px rgba(2,6,23,.06);
      min-width: 240px;
    }
    .search input{
      border:0; outline:0; width:100%;
      font-size:14px;
    }
    .btn{
      border:0; cursor:pointer;
      padding:10px 14px;
      border-radius: 999px;
      font-weight:700;
      transition: transform .06s ease, filter .15s ease, background .15s ease;
      display:inline-flex; align-items:center; gap:8px;
    }
    .btn:active{ transform: translateY(1px); }
    .btn-primary{
      background: linear-gradient(135deg, var(--blue-600), var(--blue-700));
      color: var(--white);
      box-shadow: 0 10px 24px rgba(37,99,235,.25);
    }
    .btn-primary:hover{ filter: brightness(1.03); }
    .btn-ghost{
      background: rgba(31,41,55,.06);
      color: var(--gray-900);
      border: 1px solid rgba(51,65,85,.10);
    }
    .cart-pill{
      position:relative;
    }
    .badge{
      position:absolute;
      top:-6px; right:-6px;
      min-width:18px; height:18px;
      padding:0 5px;
      border-radius: 999px;
      background: var(--orange-500);
      color: var(--white);
      font-size:12px;
      display:flex; align-items:center; justify-content:center;
      box-shadow: 0 8px 18px rgba(249,115,22,.25);
    }

    /* =========================
       Hero
       ========================= */
    .hero{padding:34px 0 18px}
    .hero-grid{
      display:grid;
      grid-template-columns: 1.25fr .75fr;
      gap:18px;
      align-items:stretch;
    }
    .card{
      background: rgba(255,255,255,.9);
      border: 1px solid rgba(51,65,85,.10);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .hero-main{
      padding:24px;
      overflow:hidden;
      position:relative;
    }
    .hero-main:before{
      content:"";
      position:absolute; inset:-60px -80px auto auto;
      width:260px; height:260px;
      background: radial-gradient(circle at 30% 30%, rgba(250,204,21,.6), rgba(249,115,22,.22), transparent 65%);
      transform: rotate(18deg);
    }
    .kicker{
      display:inline-flex; align-items:center; gap:8px;
      font-weight:800;
      color: var(--gray-800);
      background: rgba(22,163,74,.10);
      border:1px solid rgba(22,163,74,.18);
      padding:8px 12px;
      border-radius: 999px;
    }
    .dot{
      width:10px; height:10px; border-radius:999px;
      background: var(--green-600);
      box-shadow: 0 0 0 4px rgba(22,163,74,.12);
    }
    h1{
      margin:14px 0 10px;
      font-size: clamp(26px, 3.2vw, 44px);
      line-height:1.08;
      letter-spacing:-.5px;
    }
    .lead{
      margin:0 0 18px;
      color: var(--gray-700);
      font-size:16px;
      line-height:1.6;
      max-width: 60ch;
    }
    .hero-cta{
      display:flex; flex-wrap:wrap;
      gap:10px;
      align-items:center;
    }
    .tiny{
      font-size:13px; color: var(--gray-700);
      display:flex; align-items:center; gap:8px;
      margin-top:12px;
    }
    .tag{
      display:inline-flex; align-items:center; gap:8px;
      padding:8px 12px;
      border-radius: 999px;
      border:1px solid rgba(51,65,85,.10);
      background: rgba(31,41,55,.04);
      font-weight:700;
      color: var(--gray-800);
    }
    .tag i{
      width:10px; height:10px; border-radius:999px; display:inline-block;
    }
    .i-blue{background: var(--blue-600)}
    .i-orange{background: var(--orange-500)}
    .i-yellow{background: var(--yellow-400)}
    .i-green{background: var(--green-600)}

    .hero-side{
      padding:18px;
      display:flex;
      flex-direction:column;
      gap:12px;
    }
    .deal{
      padding:16px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(250,204,21,.55), rgba(249,115,22,.10));
      border: 1px solid rgba(249,115,22,.18);
    }
    .deal h3{margin:0 0 6px}
    .deal p{margin:0; color: var(--gray-700); line-height:1.5}
    .deal .pill{
      margin-top:12px;
      display:inline-flex; align-items:center; gap:8px;
      padding:8px 12px; border-radius:999px;
      background: rgba(255,255,255,.75);
      border:1px dashed rgba(249,115,22,.35);
      font-weight:800;
    }
    .ship{
      padding:16px;
      border-radius: 16px;
      background: rgba(37,99,235,.08);
      border: 1px solid rgba(37,99,235,.16);
    }
    .ship strong{color: var(--gray-900)}
    .ship p{margin:8px 0 0; color: var(--gray-700); line-height:1.5}

    /* =========================
       Product section
       ========================= */
    .section-head{
      display:flex; align-items:flex-end; justify-content:space-between;
      gap:12px;
      margin:22px 0 12px;
    }
    .section-head h2{
      margin:0;
      font-size:20px;
      letter-spacing:-.2px;
    }
    .filters{
      display:flex; gap:10px; flex-wrap:wrap;
      align-items:center;
    }
    .select{
      background: var(--white);
      border:1px solid rgba(51,65,85,.10);
      border-radius: 999px;
      padding:10px 12px;
      font-weight:700;
      color: var(--gray-800);
      box-shadow: 0 6px 18px rgba(2,6,23,.06);
    }

    .grid{
      display:grid;
      grid-template-columns: repeat(12, 1fr);
      gap:14px;
      padding-bottom: 26px;
    }
    .product{
      grid-column: span 4;
      padding:14px;
      overflow:hidden;
      position:relative;
    }
    .thumb{
      height:160px;
      border-radius: 16px;
      border: 1px solid rgba(51,65,85,.10);
      background:
        radial-gradient(120px 120px at 25% 35%, rgba(37,99,235,.18), transparent 60%),
        radial-gradient(140px 140px at 70% 50%, rgba(249,115,22,.18), transparent 60%),
        radial-gradient(160px 160px at 55% 95%, rgba(250,204,21,.16), transparent 60%),
        rgba(31,41,55,.04);
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      padding:12px;
    }
    .chip{
      display:inline-flex; align-items:center; gap:8px;
      font-size:12px;
      font-weight:900;
      padding:7px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.85);
      border:1px solid rgba(51,65,85,.12);
    }
    .chip.sale{
      background: rgba(250,204,21,.35);
      border-color: rgba(250,204,21,.55);
    }
    .chip.good{
      background: rgba(22,163,74,.14);
      border-color: rgba(22,163,74,.22);
    }
    .p-title{
      margin:12px 0 6px;
      font-weight:900;
      letter-spacing:-.2px;
    }
    .p-desc{
      margin:0 0 12px;
      color: var(--gray-700);
      line-height:1.45;
      font-size:14px;
      min-height: 40px;
    }
    .row{
      display:flex; align-items:center; justify-content:space-between; gap:10px;
    }
    .price{
      font-weight:900;
      font-size:16px;
    }
    .strike{
      color: var(--gray-700);
      font-weight:800;
      font-size:13px;
      text-decoration: line-through;
      margin-left:8px;
    }
    .add{
      background: rgba(37,99,235,.10);
      color: var(--blue-700);
      border: 1px solid rgba(37,99,235,.18);
      padding:10px 12px;
      border-radius: 999px;
      font-weight:900;
      cursor:pointer;
      transition: background .15s ease, transform .06s ease;
      white-space:nowrap;
    }
    .add:hover{ background: rgba(37,99,235,.14); }
    .add:active{ transform: translateY(1px); }

    /* =========================
       Cart drawer
       ========================= */
    .drawer-backdrop{
      position:fixed; inset:0;
      background: rgba(2,6,23,.45);
      opacity:0; pointer-events:none;
      transition: opacity .18s ease;
      z-index: 60;
    }
    .drawer{
      position:fixed; top:0; right:0; height:100%; width:min(420px, 92vw);
      background: rgba(255,255,255,.96);
      border-left: 1px solid rgba(51,65,85,.12);
      box-shadow: -20px 0 60px rgba(2,6,23,.18);
      transform: translateX(105%);
      transition: transform .22s ease;
      z-index: 70;
      display:flex; flex-direction:column;
    }
    .drawer.open{ transform: translateX(0); }
    .drawer-backdrop.open{ opacity:1; pointer-events:auto; }
    .drawer-head{
      padding:18px;
      border-bottom:1px solid rgba(51,65,85,.10);
      display:flex; align-items:center; justify-content:space-between; gap:10px;
    }
    .drawer-head h3{margin:0; letter-spacing:-.2px}
    .drawer-body{
      padding:14px 18px;
      overflow:auto;
      flex:1;
    }
    .item{
      display:grid;
      grid-template-columns: 1fr auto;
      gap:8px 10px;
      padding:12px;
      border:1px solid rgba(51,65,85,.10);
      border-radius: 16px;
      background: rgba(31,41,55,.03);
      margin-bottom:10px;
    }
    .item strong{font-weight:900}
    .qty{
      display:flex; align-items:center; gap:8px; justify-content:flex-end;
    }
    .qty button{
      width:34px; height:34px; border-radius: 999px;
      border:1px solid rgba(51,65,85,.14);
      background: rgba(255,255,255,.85);
      cursor:pointer;
      font-weight:900;
    }
    .drawer-foot{
      padding:16px 18px 18px;
      border-top:1px solid rgba(51,65,85,.10);
      background: rgba(243,244,246,.6);
    }
    .total{
      display:flex; align-items:center; justify-content:space-between;
      font-weight:900;
      margin-bottom:12px;
    }
    .note{
      font-size:13px; color: var(--gray-700); margin:8px 0 0;
    }
    .btn-checkout{
      width:100%;
      justify-content:center;
      padding:12px 14px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--orange-500), rgba(250,204,21,.95));
      color: var(--gray-900);
      box-shadow: 0 12px 26px rgba(249,115,22,.22);
    }

    /* =========================
       Footer
       ========================= */
    footer{
      padding:22px 0 30px;
      color: var(--gray-700);
    }
    .footer-grid{
      display:grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap:14px;
      padding:18px;
    }
    .footer-grid h4{margin:0 0 8px; color: var(--gray-900)}
    .footer-grid p, .footer-grid a{
      margin:0; line-height:1.6; font-weight:600;
    }
    .footer-grid a:hover{ text-decoration: underline; }

    /* =========================
       Responsive
       ========================= */
    @media (max-width: 920px){
      .hero-grid{grid-template-columns: 1fr}
      .search{min-width: 0; width: 100%;}
      .topbar{flex-wrap:wrap}
      nav{width:100%; justify-content:flex-start; flex-wrap:wrap}
      .actions{width:100%}
    }
    @media (max-width: 860px){
      .product{grid-column: span 6;}
      .footer-grid{grid-template-columns: 1fr}
    }
    @media (max-width: 520px){
      .product{grid-column: span 12;}
      .thumb{height:150px}
    }
  </style>
</head>

<body>
  <header>
    <div class="container">
      <div class="topbar">
        <a class="brand" href="#">
          <span class="logo" aria-hidden="true"></span>
          <span>ShopDemo</span>
        </a>

        <nav aria-label="Hauptnavigation">
          <a href="#produkte">Produkte</a>
          <a href="#vorteile">Vorteile</a>
          <a href="#kontakt">Kontakt</a>
        </nav>

        <div class="actions">
          <label class="search" aria-label="Produktsuche">
            <span aria-hidden="true">🔎</span>
            <input id="searchInput" placeholder="Suchen… (z.B. Hoodie)" autocomplete="off" />
          </label>

          <button class="btn btn-ghost cart-pill" id="openCartBtn" type="button" aria-haspopup="dialog" aria-controls="cartDrawer">
            🛒 Warenkorb
            <span class="badge" id="cartCount">0</span>
          </button>

          <button class="btn btn-primary" type="button" onclick="scrollToProducts()">
            Jetzt shoppen →
          </button>
        </div>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="hero" id="vorteile">
      <div class="hero-grid">
        <div class="card hero-main">
          <span class="kicker"><span class="dot" aria-hidden="true"></span> Neue Kollektion • heute -15%</span>
          <h1>Minimaler Look. <br/>Maximaler Style.</h1>
          <p class="lead">
            Eine saubere Shop-Startseite im Farbschema <b>Grau, Blau, Grün, Orange, Gelb</b>.
            Mit Produktsuche, Filter und Warenkorb (ohne Backend).
          </p>

          <div class="hero-cta">
            <button class="btn btn-primary" type="button" onclick="scrollToProducts()">Zum Sortiment</button>
            <button class="btn btn-ghost" type="button" onclick="applyPromo()">Promo anwenden</button>
          </div>

          <div class="tiny">
            <span class="tag"><i class="i-blue"></i> Blau = Primär</span>
            <span class="tag"><i class="i-green"></i> Grün = Erfolg</span>
            <span class="tag"><i class="i-orange"></i> Orange = Highlight</span>
            <span class="tag"><i class="i-yellow"></i> Gelb = Sale</span>
          </div>
        </div>

        <aside class="card hero-side">
          <div class="deal">
            <h3>⚡ Deal der Woche</h3>
            <p>Gelbe Sale-Highlights + orange Akzente für Aufmerksamkeit — ohne laut zu wirken.</p>
            <div class="pill">Code: <span id="promoCode">SUNNY15</span> ☀️</div>
          </div>

          <div class="ship">
            <strong>🚚 Versand &amp; Rückgabe</strong>
            <p>Gratis Versand ab 49 CHF • 30 Tage Rückgabe • Support innerhalb 24h</p>
          </div>
        </aside>
      </div>
    </section>

    <section id="produkte">
      <div class="section-head">
        <h2>Beliebte Produkte</h2>
        <div class="filters">
          <select id="categorySelect" class="select" aria-label="Kategorie Filter">
            <option value="all">Alle Kategorien</option>
            <option value="fashion">Fashion</option>
            <option value="tech">Tech</option>
            <option value="home">Home</option>
          </select>

          <select id="sortSelect" class="select" aria-label="Sortierung">
            <option value="popular">Sortierung: Beliebt</option>
            <option value="low">Preis: niedrig → hoch</option>
            <option value="high">Preis: hoch → niedrig</option>
          </select>
        </div>
      </div>

      <div class="grid" id="productGrid" aria-live="polite"></div>
    </section>

    <footer id="kontakt">
      <div class="card footer-grid">
        <div>
          <h4>ShopDemo</h4>
          <p>Demo-Frontend (1 Datei). Ideal als Startpunkt für deinen echten Shop.</p>
        </div>
        <div>
          <h4>Rechtliches</h4>
          <p><a href="#">Impressum</a></p>
          <p><a href="#">Datenschutz</a></p>
          <p><a href="#">AGB</a></p>
        </div>
        <div>
          <h4>Kontakt</h4>
          <p>support@shopdemo.local</p>
          <p>Mo–Fr • 09:00–18:00</p>
        </div>
      </div>
    </footer>
  </main>

  <!-- Cart Drawer -->
  <div class="drawer-backdrop" id="drawerBackdrop" aria-hidden="true"></div>
  <aside class="drawer" id="cartDrawer" role="dialog" aria-modal="true" aria-label="Warenkorb">
    <div class="drawer-head">
      <h3>Warenkorb</h3>
      <button class="btn btn-ghost" id="closeCartBtn" type="button">Schließen ✕</button>
    </div>

    <div class="drawer-body" id="cartItems"></div>

    <div class="drawer-foot">
      <div class="total">
        <span>Summe</span>
        <span id="cartTotal">CHF 0.00</span>
      </div>
      <button class="btn btn-checkout" type="button" onclick="checkout()">Zur Kasse</button>
      <p class="note" id="promoNote">Tipp: Promo <b>SUNNY15</b> für -15% (Demo)</p>
    </div>
  </aside>

  <script>
    // =========================
    // Demo-Daten
    // =========================
    const products = [
      { id:"p1", title:"Cloud Hoodie", desc:"Weich, clean, perfekt für jeden Tag.", cat:"fashion", price:69.90, sale:true, rating:"Top", },
      { id:"p2", title:"Minimal Sneaker", desc:"Leicht, bequem, zeitlos.", cat:"fashion", price:89.00, sale:false, rating:"Sehr gut", },
      { id:"p3", title:"Desk Lamp Pro", desc:"Warmweißes Licht, modernes Design.", cat:"home", price:39.90, sale:true, rating:"Bestseller", },

      { id:"p4", title:"Smart Bottle", desc:"Trinken erinnern, stylisch bleiben.", cat:"tech", price:49.90, sale:false, rating:"Neu", },
      { id:"p5", title:"Organizer Set", desc:"Mehr Ordnung, weniger Stress.", cat:"home", price:24.50, sale:false, rating:"Top", },
      { id:"p6", title:"Wireless Earbuds", desc:"Klarer Sound, starke Akkulaufzeit.", cat:"tech", price:79.00, sale:true, rating:"Top", },
    ];

    const state = {
      query: "",
      category: "all",
      sort: "popular",
      cart: new Map(), // id -> qty
      promo: null, // "SUNNY15"
    };

    // =========================
    // Helpers
    // =========================
    const CHF = new Intl.NumberFormat("de-CH", { style:"currency", currency:"CHF" });

    function scrollToProducts(){
      document.querySelector("#produkte").scrollIntoView({behavior:"smooth"});
    }

    function applyPromo(){
      state.promo = "SUNNY15";
      document.getElementById("promoNote").innerHTML = "Promo aktiv: <b>SUNNY15</b> (-15%) ✅";
      renderCart();
      openCart();
    }

    function getFilteredProducts(){
      let list = products.slice();

      if (state.category !== "all") list = list.filter(p => p.cat === state.category);
      if (state.query.trim()){
        const q = state.query.trim().toLowerCase();
        list = list.filter(p => (p.title + " " + p.desc).toLowerCase().includes(q));
      }

      if (state.sort === "low") list.sort((a,b)=>a.price-b.price);
      if (state.sort === "high") list.sort((a,b)=>b.price-a.price);

      return list;
    }

    function calcSubtotal(){
      let sum = 0;
      for (const [id, qty] of state.cart.entries()){
        const p = products.find(x => x.id === id);
        if (p) sum += p.price * qty;
      }
      return sum;
    }

    function calcTotal(){
      const sub = calcSubtotal();
      const discount = (state.promo === "SUNNY15") ? 0.15 : 0;
      return { sub, discount, total: sub * (1 - discount) };
    }

    // =========================
    // Rendering
    // =========================
    function renderProducts(){
      const grid = document.getElementById("productGrid");
      const list = getFilteredProducts();

      grid.innerHTML = list.map(p => {
        const saleChip = p.sale ? `<span class="chip sale">⭐ SALE</span>` : `<span class="chip good">✅ ${p.rating}</span>`;
        const oldPrice = p.sale ? `<span class="strike">${CHF.format(p.price * 1.18)}</span>` : "";

        return `
          <article class="card product">
            <div class="thumb" aria-hidden="true">
              ${saleChip}
              <span class="chip" title="Kategorie">${p.cat.toUpperCase()}</span>
            </div>

            <div class="p-title">${p.title}</div>
            <p class="p-desc">${p.desc}</p>

            <div class="row">
              <div>
                <span class="price">${CHF.format(p.price)}</span>
                ${oldPrice}
              </div>
              <button class="add" type="button" onclick="addToCart('${p.id}')">In den Warenkorb</button>
            </div>
          </article>
        `;
      }).join("");

      if (!list.length){
        grid.innerHTML = `
          <div class="card" style="grid-column: span 12; padding:18px;">
            <b>Keine Treffer.</b>
            <div style="margin-top:6px; color: var(--gray-700); font-weight:600;">
              Versuch eine andere Suche oder setze Filter zurück.
            </div>
          </div>
        `;
      }
    }

    function renderCart(){
      const wrap = document.getElementById("cartItems");
      const count = [...state.cart.values()].reduce((a,b)=>a+b, 0);
      document.getElementById("cartCount").textContent = String(count);

      if (count === 0){
        wrap.innerHTML = `
          <div class="card" style="padding:14px;">
            <b>Dein Warenkorb ist leer.</b>
            <div style="margin-top:6px; color: var(--gray-700); font-weight:600;">
              Füge Produkte hinzu – dann erscheint hier die Übersicht.
            </div>
          </div>
        `;
      } else {
        wrap.innerHTML = [...state.cart.entries()].map(([id, qty]) => {
          const p = products.find(x => x.id === id);
          if (!p) return "";
          return `
            <div class="item">
              <div>
                <strong>${p.title}</strong>
                <div style="color: var(--gray-700); font-weight:700; margin-top:4px;">
                  ${CHF.format(p.price)} • <span style="color: var(--green-600); font-weight:900;">${p.sale ? "SALE" : "Standard"}</span>
                </div>
              </div>

              <div class="qty" aria-label="Menge ändern">
                <button type="button" onclick="changeQty('${id}', -1)" aria-label="Minus">−</button>
                <span style="min-width:18px; text-align:center; font-weight:900;">${qty}</span>
                <button type="button" onclick="changeQty('${id}', 1)" aria-label="Plus">+</button>
              </div>
            </div>
          `;
        }).join("");
      }

      const { sub, discount, total } = calcTotal();
      const totalEl = document.getElementById("cartTotal");
      totalEl.textContent = CHF.format(total);

      // Kleine Zusatzinfo, wenn Promo aktiv
      if (discount > 0){
        totalEl.title = `Zwischensumme: ${CHF.format(sub)} | Rabatt: -${Math.round(discount*100)}%`;
      } else {
        totalEl.title = `Zwischensumme: ${CHF.format(sub)}`;
      }
    }

    // =========================
    // Cart actions
    // =========================
    function addToCart(id){
      const current = state.cart.get(id) || 0;
      state.cart.set(id, current + 1);
      renderCart();
      openCart();
    }

    function changeQty(id, delta){
      const current = state.cart.get(id) || 0;
      const next = current + delta;
      if (next <= 0) state.cart.delete(id);
      else state.cart.set(id, next);
      renderCart();
    }

    function checkout(){
      const { total } = calcTotal();
      alert("Demo-Checkout ✅\nGesamt: " + CHF.format(total) + "\n(Kein echtes Bezahlsystem verbunden.)");
      state.cart.clear();
      state.promo = null;
      document.getElementById("promoNote").innerHTML = "Tipp: Promo <b>SUNNY15</b> für -15% (Demo)";
      renderCart();
      closeCart();
    }

    // =========================
    // Drawer open/close
    // =========================
    const drawer = document.getElementById("cartDrawer");
    const backdrop = document.getElementById("drawerBackdrop");

    function openCart(){
      drawer.classList.add("open");
      backdrop.classList.add("open");
      backdrop.setAttribute("aria-hidden", "false");
    }
    function closeCart(){
      drawer.classList.remove("open");
      backdrop.classList.remove("open");
      backdrop.setAttribute("aria-hidden", "true");
    }

    document.getElementById("openCartBtn").addEventListener("click", openCart);
    document.getElementById("closeCartBtn").addEventListener("click", closeCart);
    backdrop.addEventListener("click", closeCart);
    window.addEventListener("keydown", (e)=>{ if(e.key === "Escape") closeCart(); });

    // =========================
    // Filters / Search
    // =========================
    document.getElementById("searchInput").addEventListener("input", (e)=>{
      state.query = e.target.value;
      renderProducts();
    });

    document.getElementById("categorySelect").addEventListener("change", (e)=>{
      state.category = e.target.value;
      renderProducts();
    });

    document.getElementById("sortSelect").addEventListener("change", (e)=>{
      state.sort = e.target.value;
      renderProducts();
    });

    // Initial render
    renderProducts();
    renderCart();
  </script>
</body>
</html>
